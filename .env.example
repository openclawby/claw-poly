# ===== Required 必填 =====
# Register at https://openclawby.com to get your API key
# 注册 https://openclawby.com 获取 API Key(市场数据通道,免费档可用)
CLAWBY_API_KEY=pk_your_key_here

# ===== Optional 可选 =====
# Legacy single-page admin (/admin-lite) password; the React admin is auth-free on 127.0.0.1
ADMIN_PASSWORD=change-me

# ===== Live trading 实盘(全部可留空,paper 模式无需)=====
# 推荐在管理台「参数设置」页填私钥/资金地址/签名类型(会自动写入本文件)
# PM_PRIVATE_KEY=0x...
# PM_FUNDER=0x...
# PM_SIGNATURE_TYPE=0        # 0=EOA 直签 1=邮箱Magic 2=网页代理钱包
# POLYGON_RPC=https://polygon-rpc.com

# DB_PATH=pmbot.db
# PORT=8643

# ===== Required 必填 =====
# Register at https://openclawby.com to get your API key
# 注册 https://openclawby.com 获取 API Key(市场数据通道,免费档可用)
CLAWBY_API_KEY=pk_your_key_here

# ===== Optional 可选 =====
# Legacy single-page admin (/admin-lite) password; the React admin is auth-free on 127.0.0.1
ADMIN_PASSWORD=change-me

# ===== Live trading 实盘(全部可留空,paper 模式无需)=====
# 推荐全部在管理台「参数设置」页填写,系统会自动写回本文件:
#   钱包私钥 / Relayer 密钥 / 一键开通交易账户(自动填 funder 与签名类型)
# PM_PRIVATE_KEY=0x...        # 钱包私钥,只放本地
# PM_RELAYER_API_KEY=...      # Polymarket 免 gas 通道密钥(开通账户/充值提现所需)
# PM_FUNDER=0x...             # 交易账户地址;一键开通会自动写入
# PM_SIGNATURE_TYPE=3         # 0=EOA 1=邮箱Magic 2=旧网页代理 3=充值钱包(现行)
# PM_SIGNER_ADDRESS=0x...     # 可选;留空则自动从私钥推导
# POLYGON_RPC=https://polygon-bor-rpc.publicnode.com

# DB_PATH=pmbot.db
# PORT=8643
